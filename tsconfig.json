{
    "include": ["src", "node_modules/ultimate-crosscode-typedefs/crosscode-ccloader-all.d.ts", "node_modules/cc-vim/src/global.d.ts"],
    "compilerOptions": {
        "target": "ES2020",
        "types": [
            "node",
            "chrome",
            "jquery",
            "bun"
        ],
        "module": "preserve",
        "rootDir": "./src",
        "moduleResolution": "bundler",
        "paths": {
            "cc-map-util/*": ["../node_modules/cc-map-util/src/*"],
            "prettier/*": ["../node_modules/prettier/*"]
        },
        "allowJs": true,
        "noEmit": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "verbatimModuleSyntax": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "noUncheckedSideEffectImports": true,
        "allowImportingTsExtensions": false
    }
}
